{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "includes": ["**/*.js", "**/*.json", "!node_modules", "!package-lock.json"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noInnerDeclarations": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "globals": [
      "chrome",
      "console",
      "window",
      "document",
      "fetch",
      "setTimeout",
      "clearTimeout",
      "setInterval",
      "clearInterval"
    ]
  }
}
